<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MauiApp1.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Keep your existing dictionaries if you had them -->
            <!--
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
        <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
      -->

            <!-- ===== Modern palette ===== -->
            <Color x:Key="Surface">#0B1020</Color>
            <Color x:Key="Surface2">#111930</Color>
            <Color x:Key="Card">#151F3A</Color>
            <Color x:Key="Accent">#8B5CF6</Color>
            <Color x:Key="Accent2">#4F46E5</Color>
            <Color x:Key="Subtle">#94A3B8</Color>

            <!-- Status colors -->
            <Color x:Key="Ok">#34D399</Color>
            <Color x:Key="Warn">#F59E0B</Color>
            <Color x:Key="Danger">#F87171</Color>

            <!-- Header gradient -->
            <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#9B5CF677" Offset="0.0"/>
                <GradientStop Color="#4F46E577" Offset="1.0"/>
            </LinearGradientBrush>

            <!-- Page backdrop -->
            <LinearGradientBrush x:Key="PageBackdrop" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0B1020" Offset="0.0"/>
                <GradientStop Color="#0C0F24" Offset="0.5"/>
                <GradientStop Color="#0B1020" Offset="1.0"/>
            </LinearGradientBrush>

            <!-- Pill chip button -->
            <Style x:Key="ChipButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#1A2544"/>
                <Setter Property="TextColor" Value="#E5E7EB"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="CornerRadius" Value="18"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="BorderColor" Value="#2A365C"/>
                <Setter Property="BorderWidth" Value="1"/>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#00000055" Radius="10" Opacity="0.25" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Selected pill -->
            <Style x:Key="ChipButtonSelected" TargetType="Button" BasedOn="{StaticResource ChipButton}">
                <Setter Property="BackgroundColor" Value="#121A33"/>
                <Setter Property="BorderColor" Value="{StaticResource Accent}"/>
                <Setter Property="TextColor" Value="White"/>
            </Style>

            <!-- Glass card (Border, not Frame) -->
            <Style x:Key="GlassCard" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A2544E0" Offset="0.0"/>
                            <GradientStop Color="#111A33E0" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Stroke">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5AA" Offset="0.0"/>
                            <GradientStop Color="#8B5CF6AA" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="StrokeThickness" Value="0.6"/>
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="18"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#00000066" Radius="14" Opacity="0.28" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="18"/>
            </Style>

            <!-- Small labels -->
            <Style x:Key="Caption" TargetType="Label">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextColor" Value="{StaticResource Subtle}"/>
            </Style>
            <Style x:Key="Metric" TargetType="Label">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>