<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:charts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
    BackgroundColor="#0F172A"
    Title="Analytics">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

            <Label
                Text="Analytics"
                TextColor="White"
                FontSize="30"
                FontAttributes="Bold" />

            <Frame
                BackgroundColor="#1E293B"
                CornerRadius="25"
                Padding="20"
                HasShadow="False">

                <VerticalStackLayout>
                    <Label
                        Text="Total Balance"
                        TextColor="#94A3B8" />

                    <Label
                        x:Name="BalanceLabel"
                        Text="$0.00"
                        TextColor="White"
                        FontSize="34"
                        FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                <Frame
                    BackgroundColor="#1E293B"
                    CornerRadius="20"
                    Padding="15"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Income"
                            TextColor="#94A3B8" />

                        <Label
                            x:Name="IncomeLabel"
                            Text="$0"
                            TextColor="#22C55E"
                            FontAttributes="Bold"
                            FontSize="20" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="1"
                    BackgroundColor="#1E293B"
                    CornerRadius="20"
                    Padding="15"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Expense"
                            TextColor="#94A3B8" />

                        <Label
                            x:Name="ExpenseLabel"
                            Text="$0"
                            TextColor="#EF4444"
                            FontAttributes="Bold"
                            FontSize="20" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Text="Spending"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold" />

                <Button
                    x:Name="SwitchButton"
                    Text="Bar"
                    Grid.Column="1"
                    Clicked="OnSwitchChart"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    CornerRadius="15"
                    Padding="14,6" />
            </Grid>

            <Frame
                BackgroundColor="#1E293B"
                CornerRadius="25"
                Padding="20"
                HasShadow="False">

                <Grid>
                    <charts:ChartView
                        x:Name="DonutChartView"
                        HeightRequest="260"
                        WidthRequest="260"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="True" />

                    <VerticalStackLayout
                        x:Name="ModernBarLayout"
                        Spacing="16"
                        IsVisible="False" />
                </Grid>
            </Frame>

            <VerticalStackLayout
                x:Name="LegendLayout"
                Spacing="10" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>




