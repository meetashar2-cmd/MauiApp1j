<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:charts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
    BackgroundColor="#0F172A"
    Title="Analytics">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

            <Label
                Text="Analytics"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"/>

            <Label Text="Total Expenses" TextColor="Gray"/>
            <Label x:Name="TotalExpensesLabel"
                   Text="{Binding TotalExpensesText}"
                   FontSize="24"
                   TextColor="White"/>

            <Label Text="Top Category" TextColor="Gray"/>
            <Label x:Name="TopCategoryLabel"
                   Text="{Binding TopCategoryText}"
                   FontSize="20"
                   TextColor="White"/>

            </Grid>

            <!-- Line -->
            <lvc:LineChart
                Series="{Binding DailyLineSeries}"
                XAxes="{Binding DailyXAxes}"
                YAxes="{Binding DailyYAxes}"
                HeightRequest="250"/>

            <!-- Breakdown list -->
            <CollectionView x:Name="AnalyticsList"
                            ItemsSource="{Binding AnalyticsItems}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">

                            <BoxView
                                WidthRequest="10"
                                HeightRequest="10"
                                CornerRadius="5"
                                Color="{Binding Category, Converter={StaticResource CatColor}}"/>

                            <Label Grid.Column="1"
                                   Text="{Binding Category}"
                                   TextColor="White"/>

                            <Label Grid.Column="2"
                                   Text="{Binding Amount, StringFormat='${0:F2}'}"
                                   TextColor="White"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
