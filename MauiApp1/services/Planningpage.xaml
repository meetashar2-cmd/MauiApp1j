<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.PlanningPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    <ScrollView>

                   FontAttributes="Bold"

                <Picker.Items>
                    <x:String>Food</x:String>
                    <x:String>Travel</x:String>
                    <x:String>Bills</x:String>
                    <x:String>Entertainment</x:String>
                </Picker.Items>
            </Picker>

                   Keyboard="Numeric"
                   TextColor="White"

                    Clicked="OnAddPlan"

            <!-- Plans List -->
            <CollectionView x:Name="PlansList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                                       TextColor="White"


                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>