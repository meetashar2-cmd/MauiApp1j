<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.SavingsGoalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#061224"
    Shell.NavBarIsVisible="False"
    Title="Savings Goals">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,30" Spacing="22">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Savings Goals"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Track your saving progress account-wise"
                        FontSize="14"
                        TextColor="#8FA3BF" />
                </VerticalStackLayout>

                <Frame
                    HeightRequest="52"
                    WidthRequest="52"
                    CornerRadius="26"
                    Padding="0"
                    BackgroundColor="#10213A"
                    HasShadow="False"
                    BorderColor="#1E3353">

                    <Label
                        Text="🎯"
                        FontSize="22"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Frame>

            </Grid>

            <!-- Top card -->
            <Frame
                CornerRadius="28"
                Padding="20"
                HasShadow="False">

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4F46E5" Offset="0" />
                        <GradientStop Color="#7C3AED" Offset="0.6" />
                        <GradientStop Color="#A855F7" Offset="1" />
                    </LinearGradientBrush>
                </Frame.Background>

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Goal Tracking"
                        FontSize="14"
                        TextColor="#E9D5FF" />

                    <Label
                        Text="Save with purpose"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Create saving goals and monitor your progress clearly."
                        FontSize="13"
                        TextColor="#F3E8FF" />
                </VerticalStackLayout>
            </Frame>

            <!-- Form -->
            <Frame
                BackgroundColor="#0D1B2E"
                CornerRadius="26"
                Padding="18"
                HasShadow="False"
                BorderColor="#1A2B45">

                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="New Savings Goal"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <!-- Account -->
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Account"
                            FontSize="13"
                            TextColor="#9FB2CC" />

                        <Border
                            Stroke="#243754"
                            StrokeThickness="1.2"
                            BackgroundColor="#12233B"
                            StrokeShape="RoundRectangle 18">

                            <Picker
                                x:Name="AccountPicker"
                                Title="Choose an account"
                                TitleColor="#94A3B8"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Margin="14,6"
                                SelectedIndexChanged="OnAccountChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Goal name -->
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Goal Name"
                            FontSize="13"
                            TextColor="#9FB2CC" />

                        <Border
                            Stroke="#243754"
                            StrokeThickness="1.2"
                            BackgroundColor="#12233B"
                            StrokeShape="RoundRectangle 18">

                            <Entry
                                x:Name="GoalNameEntry"
                                Placeholder="Enter goal name"
                                PlaceholderColor="#6B85A3"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Margin="14,10" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Target amount -->
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Target Amount"
                            FontSize="13"
                            TextColor="#9FB2CC" />

                        <Border
                            Stroke="#243754"
                            StrokeThickness="1.2"
                            BackgroundColor="#12233B"
                            StrokeShape="RoundRectangle 18">

                            <Grid ColumnDefinitions="Auto,*" Padding="14,4">
                                <Label
                                    Text="$"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#A78BFA"
                                    VerticalOptions="Center" />

                                <Entry
                                    Grid.Column="1"
                                    x:Name="TargetAmountEntry"
                                    Placeholder="Enter target amount"
                                    PlaceholderColor="#6B85A3"
                                    Keyboard="Numeric"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Saved amount -->
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Saved Amount"
                            FontSize="13"
                            TextColor="#9FB2CC" />

                        <Border
                            Stroke="#243754"
                            StrokeThickness="1.2"
                            BackgroundColor="#12233B"
                            StrokeShape="RoundRectangle 18">

                            <Grid ColumnDefinitions="Auto,*" Padding="14,4">
                                <Label
                                    Text="$"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#A78BFA"
                                    VerticalOptions="Center" />

                                <Entry
                                    Grid.Column="1"
                                    x:Name="SavedAmountEntry"
                                    Placeholder="Enter current saved amount"
                                    PlaceholderColor="#6B85A3"
                                    Keyboard="Numeric"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Button
                        Text="Save Goal"
                        Clicked="OnSaveGoalClicked"
                        HeightRequest="54"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="#7C3AED" />

                </VerticalStackLayout>
            </Frame>

            <!-- Section title -->
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Text="Saved Goals"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Frame
                    Grid.Column="1"
                    BackgroundColor="#10213A"
                    CornerRadius="14"
                    Padding="12,6"
                    HasShadow="False"
                    BorderColor="#1E3353">

                    <Label
                        Text="Progress"
                        FontSize="12"
                        TextColor="#A78BFA" />
                </Frame>
            </Grid>

            <!-- Goals list -->
            <CollectionView x:Name="GoalsList" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Frame
                        BackgroundColor="#0D1B2E"
                        BorderColor="#1A2B45"
                        CornerRadius="24"
                        Padding="28"
                        HasShadow="False">

                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label
                                Text="🎯"
                                FontSize="34"
                                HorizontalOptions="Center" />

                            <Label
                                Text="No savings goals yet"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Center" />

                            <Label
                                Text="Create your first goal above"
                                FontSize="13"
                                TextColor="#8FA3BF"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            BackgroundColor="#0D1B2E"
                            BorderColor="#1A2B45"
                            CornerRadius="22"
                            Padding="14"
                            Margin="0,0,0,12"
                            HasShadow="False">

                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                                    <Frame
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="22"
                                        Padding="0"
                                        BackgroundColor="#162844"
                                        HasShadow="False"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="🎯"
                                            FontSize="18"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label
                                            Text="{Binding GoalName}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="White"
                                            LineBreakMode="TailTruncation" />

                                        <Label
                                            Text="{Binding SavedAmount, StringFormat='Saved: ${0:F2}'}"
                                            FontSize="12"
                                            TextColor="#8FA3BF" />
                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding TargetAmount, StringFormat='${0:F0}'}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#C4B5FD"
                                        VerticalOptions="Center"
                                        HorizontalTextAlignment="End" />
                                </Grid>

                                <ProgressBar
                                    Progress="{Binding Progress}"
                                    ProgressColor="#7C3AED"
                                    BackgroundColor="#1E293B"
                                    HeightRequest="8" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label
                                        Text="{Binding Remaining, StringFormat='Remaining: ${0:F2}'}"
                                        FontSize="12"
                                        TextColor="#94A3B8"
                                        LineBreakMode="TailTruncation" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding ProgressText}"
                                        FontSize="12"
                                        TextColor="#A78BFA"
                                        HorizontalTextAlignment="End" />
                                </Grid>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>