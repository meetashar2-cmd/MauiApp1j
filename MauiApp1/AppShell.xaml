<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:MauiApp1"
    Shell.NavBarIsVisible="True">

    <TabBar>

        <Tab Title="Dashboard">
            <ShellContent
                Title="Dashboard"
                ContentTemplate="{DataTemplate pages:DashboardPage}"
                Route="dashboard" />
        </Tab>

        <Tab Title="Add">
            <ShellContent
                Title="Add Transaction"
                ContentTemplate="{DataTemplate pages:AddTransactionPage}"
                Route="add" />
        </Tab>

        <Tab Title="Analytics">
            <ShellContent
                Title="Analytics"
                ContentTemplate="{DataTemplate pages:AnalyticsPage}"
                Route="analytics" />
        </Tab>

    </TabBar>

</Shell>