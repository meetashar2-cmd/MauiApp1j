<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0F172A"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- HEADER -->
            <Label Text="Dashboard"
                   FontSize="26"
                   TextColor="White"
                   FontAttributes="Bold"/>

            <!-- ACCOUNT SECTION -->
            <Frame BackgroundColor="#1E293B" CornerRadius="20" Padding="15">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Select Account"
                           TextColor="Gray"/>

                    <Picker x:Name="AccountPicker"
                            Title="Choose account"
                            SelectedIndexChanged="OnAccountChanged"/>

                    <Button Text="➕ Add Account"
                            Clicked="OnAddAccountClicked"
                            BackgroundColor="#6366F1"
                            TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <!-- BALANCE -->
            <Frame BackgroundColor="#1E293B" CornerRadius="20" Padding="20">
                <VerticalStackLayout>
                    <Label Text="Balance" TextColor="Gray"/>
                    <Label x:Name="BalanceLabel"
                           Text="$0.00"
                           FontSize="28"
                           TextColor="White"
                           FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <!-- INCOME / EXPENSE -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                <Frame BackgroundColor="#1E293B" CornerRadius="20" Padding="15">
                    <VerticalStackLayout>
                        <Label Text="Income" TextColor="Gray"/>
                        <Label x:Name="IncomeLabel"
                               Text="$0"
                               TextColor="Green"
                               FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1"
                       BackgroundColor="#1E293B"
                       CornerRadius="20"
                       Padding="15">
                    <VerticalStackLayout>
                        <Label Text="Expense" TextColor="Gray"/>
                        <Label x:Name="ExpenseLabel"
                               Text="$0"
                               TextColor="Red"
                               FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- BUTTONS -->
            <Button Text="➕ Add Transaction"
                    Clicked="OnAddClicked"/>

            <Button Text="📊 Analytics"
                    Clicked="OnAnalyticsClicked"/>

            <Button Text="📅 Planning"
                    Clicked="OnPlanningClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>