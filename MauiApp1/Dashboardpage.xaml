<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#020617"
    Shell.NavBarIsVisible="False">

    <Grid>

        <ScrollView>

            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- TOP BAR -->
                <Grid ColumnDefinitions="*,Auto">

                    <VerticalStackLayout>

                        <Label
                            Text="Welcome Back 👋"
                            FontSize="16"
                            TextColor="#94A3B8"/>

                        <Label
                            Text="Smart Budget"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White"/>

                    </VerticalStackLayout>

                    <Frame
                        HeightRequest="45"
                        WidthRequest="45"
                        CornerRadius="22"
                        BackgroundColor="#0F172A"
                        HorizontalOptions="End">

                        <Label
                            Text="👤"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            FontSize="20"/>

                    </Frame>

                </Grid>

                <!-- ACCOUNT SELECTOR -->
                <Frame
                    BackgroundColor="#0F172A"
                    CornerRadius="20"
                    Padding="15">

                    <Grid ColumnDefinitions="*,Auto">

                        <VerticalStackLayout>

                            <Label
                                Text="Account"
                                TextColor="#94A3B8"
                                FontSize="13"/>

                            <Picker
                                x:Name="AccountPicker"
                                TextColor="White"
                                SelectedIndexChanged="OnAccountChanged"/>

                        </VerticalStackLayout>

                        <Button
                            Grid.Column="1"
                            Text="+"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="#7C3AED"
                            TextColor="White"
                            Clicked="OnAddAccountClicked"/>

                    </Grid>

                </Frame>

                <!-- BALANCE CARD -->
                <Frame
                    CornerRadius="25"
                    Padding="20"
                    HasShadow="True">

                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5" Offset="0"/>
                            <GradientStop Color="#9333EA" Offset="1"/>
                        </LinearGradientBrush>
                    </Frame.Background>

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="Total Balance"
                            TextColor="White"
                            Opacity="0.8"/>

                        <Label
                            x:Name="BalanceLabel"
                            Text="$0.00"
                            FontSize="38"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Label
                            Text="Updated just now"
                            FontSize="12"
                            TextColor="White"
                            Opacity="0.7"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- INCOME EXPENSE -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                    <!-- Income -->
                    <Frame
                        BackgroundColor="#022c22"
                        CornerRadius="20"
                        Padding="15">

                        <VerticalStackLayout>

                            <Label
                                Text="Income"
                                TextColor="#86efac"/>

                            <Label
                                x:Name="IncomeLabel"
                                Text="$0"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="#22C55E"/>

                        </VerticalStackLayout>

                    </Frame>

                    <!-- Expense -->
                    <Frame
                        Grid.Column="1"
                        BackgroundColor="#3f0000"
                        CornerRadius="20"
                        Padding="15">

                        <VerticalStackLayout>

                            <Label
                                Text="Expense"
                                TextColor="#fca5a5"/>

                            <Label
                                x:Name="ExpenseLabel"
                                Text="$0"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="#EF4444"/>

                        </VerticalStackLayout>

                    </Frame>

                </Grid>

                <!-- QUICK ACTIONS -->
                <Label
                    Text="Quick Actions"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                    <Frame BackgroundColor="#0F172A" CornerRadius="18" Padding="15">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="➕" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Add" TextColor="White"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#0F172A" CornerRadius="18" Padding="15">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="📊" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Analytics" TextColor="White"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#0F172A"
       CornerRadius="18"
       Padding="15">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlanningClicked"/>
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="📅" FontSize="20"/>
                            <Label Text="Planning" TextColor="White"/>
                        </VerticalStackLayout>

                    </Frame>

                </Grid>

                

                <CollectionView x:Name="RecentList">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Frame
                                BackgroundColor="#0F172A"
                                CornerRadius="18"
                                Padding="15"
                                Margin="0,5">

                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <Frame
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        BackgroundColor="#7C3AED">

                                        <Label
                                            Text="💸"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>

                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" Margin="10,0">

                                        <Label
                                            Text="{Binding Title}"
                                            TextColor="White"
                                            FontAttributes="Bold"/>

                                        <Label
                                            Text="{Binding Category}"
                                            FontSize="12"
                                            TextColor="#94A3B8"/>

                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding Amount}"
                                        TextColor="#7C3AED"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"/>

                                </Grid>

                            </Frame>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

        <!-- FLOATING BUTTON -->
        <Button
            Text="+"
            WidthRequest="65"
            HeightRequest="65"
            CornerRadius="32"
            BackgroundColor="#7C3AED"
            TextColor="White"
            FontSize="28"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="20"
            Clicked="OnAddClicked"/>

    </Grid>

</ContentPage>