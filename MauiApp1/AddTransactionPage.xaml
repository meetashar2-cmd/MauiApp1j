<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    x:Class="MauiApp1.AddTransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Transaction">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry x:Name="TitleEntry" Placeholder="Title" />

        <Entry x:Name="AmountEntry"
           Placeholder="Amount (positive for income, negative for expense)"
           Keyboard="Numeric" />

        <!-- Wrap items in <Picker.Items> -->
        <Picker x:Name="TypePicker" Title="Select Type">
            <Picker.Items>
                <x:String>Income</x:String>
                <x:String>Expense</x:String>
            </Picker.Items>
        </Picker>

        <!-- Wrap items in <Picker.Items> -->
        <Picker x:Name="CategoryPicker" Title="Category">
            <Picker.Items>
                <x:String>Food</x:String>
                <x:String>Transport</x:String>
                <x:String>Salary</x:String>
                <x:String>Shopping</x:String>
                <x:String>Entertainment</x:String>
                <x:String>Other</x:String>
            </Picker.Items>
        </Picker>

        <DatePicker x:Name="DatePicker" />

        <Button Text="Save"
            BackgroundColor="#2196F3"
            TextColor="White"
            Clicked="OnSaveClicked"/>
    </VerticalStackLayout>
</ContentPage>