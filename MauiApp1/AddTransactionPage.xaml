<ContentPage
    x:Class="MauiApp1.AddTransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Entry x:Name="TitleEntry" Placeholder="Title" />
        <Entry x:Name="AmountEntry" Placeholder="Amount" Keyboard="Numeric"/>

        <Picker x:Name="TypePicker">
            <Picker.Items>
                <x:String>Expense</x:String>
                <x:String>Income</x:String>
            </Picker.Items>
        </Picker>

        <Picker x:Name="CategoryPicker">
            <Picker.Items>
                <x:String>Food</x:String>
                <x:String>Travel</x:String>
                <x:String>Bills</x:String>
                <x:String>Entertainment</x:String>
            </Picker.Items>
        </Picker>

        <DatePicker x:Name="DatePicker"/>
        <Picker x:Name="AccountPicker" Title="Select Account"/>

        <Button Text="Save" Clicked="OnSaveClicked"/>
    </VerticalStackLayout>
</ContentPage>