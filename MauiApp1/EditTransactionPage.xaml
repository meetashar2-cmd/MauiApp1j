<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    x:Class="MauiApp1.EditTransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Edit Transaction">

    <VerticalStackLayout Padding="20" Spacing="14">
        <Entry x:Name="TitleEntry" Placeholder="Title"/>
        <Entry x:Name="AmountEntry" Placeholder="Amount" Keyboard="Numeric"/>

        <Picker x:Name="TypePicker" Title="Type">
            <x:String>Income</x:String>
            <x:String>Expense</x:String>
        </Picker>

        <Picker x:Name="CategoryPicker" Title="Category">
            <x:String>Food</x:String>
            <x:String>Transport</x:String>
            <x:String>Salary</x:String>
            <x:String>Shopping</x:String>
            <x:String>Entertainment</x:String>
            <x:String>Other</x:String>
        </Picker>

        <DatePicker x:Name="DatePicker" />

        <Button Text="Save Changes" Clicked="OnSaveClicked"/>
    </VerticalStackLayout>
</ContentPage>